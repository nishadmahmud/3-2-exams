{"PageNumber":2,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Elgamal cryptosystem","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":305},"LeftTop":{"X":219,"Y":179},"RightBottom":{"X":1357,"Y":305},"RightTop":{"X":1357,"Y":179}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● The Elgamal cryptosystem, named after its inventor, Taher Elgamal, is a public-key cryptosystem that uses randomisation","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":561},"LeftTop":{"X":216,"Y":427},"RightBottom":{"X":2664,"Y":561},"RightTop":{"X":2664,"Y":427}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● Enabling independent encryptions of the same plaintext to produce different ciphertexts.","Level":0,"Polygon":{"LeftBottom":{"X":320,"Y":629},"LeftTop":{"X":320,"Y":566},"RightBottom":{"X":2535,"Y":629},"RightTop":{"X":2535,"Y":566}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● In the number system $Z_p$, all arithmetic is done modulo a prime number, $p$","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":726},"LeftTop":{"X":216,"Y":640},"RightBottom":{"X":2425,"Y":726},"RightTop":{"X":2425,"Y":640}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● A number, g in $Z_p$, is said to be a generator or primitive root modulo p if, for each positive integer k in $Z_p$, k is in range [0, p-2], there is a unique integer i such that i = g^k mod p","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":927},"LeftTop":{"X":216,"Y":733},"RightBottom":{"X":2760,"Y":927},"RightTop":{"X":2760,"Y":733}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● For example,","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1018},"LeftTop":{"X":216,"Y":947},"RightBottom":{"X":648,"Y":1018},"RightTop":{"X":648,"Y":947}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"● 3 is a primitive root modulo 7","Level":0,"Polygon":{"LeftBottom":{"X":326,"Y":1084},"LeftTop":{"X":326,"Y":1023},"RightBottom":{"X":1098,"Y":1084},"RightTop":{"X":1098,"Y":1023}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"$$ \\bullet 3^0 \\bmod 7 = 1, 3^1 \\bmod 7 = 3, 3^2 \\bmod 7 = 2, 3^3 \\bmod 7 = 6, 3^4 \\bmod 7 = 4, 3^5 \\bmod 7 = 5. $$","Level":0,"Polygon":{"LeftBottom":{"X":326,"Y":1149},"LeftTop":{"X":326,"Y":1084},"RightBottom":{"X":2356,"Y":1149},"RightTop":{"X":2356,"Y":1084}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"● Here, you get all the possible results: 1,3,2,6,4,5","Level":0,"Polygon":{"LeftBottom":{"X":326,"Y":1219},"LeftTop":{"X":326,"Y":1156},"RightBottom":{"X":1553,"Y":1219},"RightTop":{"X":1553,"Y":1156}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"● 3 is not a primitive root modulo 11","Level":0,"Polygon":{"LeftBottom":{"X":326,"Y":1348},"LeftTop":{"X":326,"Y":1287},"RightBottom":{"X":1227,"Y":1348},"RightTop":{"X":1227,"Y":1287}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"$$ \\bullet\\ 3^0\\ \\mathrm{mod}\\ 11=1,3^1\\ \\mathrm{mod}\\ 11=3,3^2\\ \\mathrm{mod}\\ 11=9,3^3\\ \\mathrm{mod}\\ 11=5,3^4\\ \\mathrm{mod}\\ 11=4,3^5\\ \\mathrm{mod}\\ 11=1. $$","Level":0,"Polygon":{"LeftBottom":{"X":326,"Y":1412},"LeftTop":{"X":326,"Y":1347},"RightBottom":{"X":2544,"Y":1412},"RightTop":{"X":2544,"Y":1347}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"● You get 1, 3, 9, 5, 4 and this sequence repeats after $3^5$","Level":0,"Polygon":{"LeftBottom":{"X":326,"Y":1478},"LeftTop":{"X":326,"Y":1416},"RightBottom":{"X":1688,"Y":1478},"RightTop":{"X":1688,"Y":1416}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}