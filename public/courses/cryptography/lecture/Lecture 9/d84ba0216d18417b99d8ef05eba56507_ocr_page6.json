{"PageNumber":6,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Elgamal cryptosystem","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":308},"LeftTop":{"X":219,"Y":179},"RightBottom":{"X":1357,"Y":308},"RightTop":{"X":1357,"Y":179}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● Note that Bob doesn't need to know the random value, k, to decrypt a message that was encrypted using this value","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":621},"LeftTop":{"X":216,"Y":441},"RightBottom":{"X":2330,"Y":621},"RightTop":{"X":2330,"Y":441}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● And Alice didn't need to know Bob's secret key to encrypt the message for him in the first place","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":827},"LeftTop":{"X":216,"Y":655},"RightBottom":{"X":2368,"Y":827},"RightTop":{"X":2368,"Y":655}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● Instead, Alice got $g^x$, as $y$, from Bob's public key, and Bob got $g^k$, as $a$, from Alice's ciphertext","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1039},"LeftTop":{"X":216,"Y":864},"RightBottom":{"X":2529,"Y":1039},"RightTop":{"X":2529,"Y":864}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● Alice raised y to the power k and Bob raised a to the power x, and in so doing they implicitly computed a type of one-time shared key, $g^{xk}$","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1343},"LeftTop":{"X":216,"Y":1078},"RightBottom":{"X":2558,"Y":1343},"RightTop":{"X":2558,"Y":1078}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● which Alice used for encryption and Bob used for decryption","Level":0,"Polygon":{"LeftBottom":{"X":326,"Y":1434},"LeftTop":{"X":326,"Y":1363},"RightBottom":{"X":2140,"Y":1434},"RightTop":{"X":2140,"Y":1363}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}