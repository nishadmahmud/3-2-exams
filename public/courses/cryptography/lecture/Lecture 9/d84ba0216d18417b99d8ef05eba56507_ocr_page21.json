{"PageNumber":21,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Hash Function: birthday attack","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":303},"LeftTop":{"X":219,"Y":179},"RightBottom":{"X":1829,"Y":303},"RightTop":{"X":1829,"Y":179}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● The problem is to compute the approximate probability that in a group of $n$ people, at least two have the same birthday","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":589},"LeftTop":{"X":219,"Y":436},"RightBottom":{"X":2509,"Y":589},"RightTop":{"X":2509,"Y":436}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● The goal is to compute $P(A)$","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":694},"LeftTop":{"X":219,"Y":616},"RightBottom":{"X":1141,"Y":694},"RightTop":{"X":1141,"Y":616}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● the probability that at least two people in the room have the same birthday.","Level":0,"Polygon":{"LeftBottom":{"X":323,"Y":773},"LeftTop":{"X":323,"Y":707},"RightBottom":{"X":2408,"Y":773},"RightTop":{"X":2408,"Y":707}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● However, it is simpler to calculate $P(A')$","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":877},"LeftTop":{"X":219,"Y":801},"RightBottom":{"X":1501,"Y":877},"RightTop":{"X":1501,"Y":801}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● the probability that no two people in the room have the same birthday","Level":0,"Polygon":{"LeftBottom":{"X":323,"Y":956},"LeftTop":{"X":323,"Y":890},"RightBottom":{"X":2276,"Y":956},"RightTop":{"X":2276,"Y":890}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"● Because $A$ and $A'$ are the only two possibilities and are also mutually exclusive, $P(A) = 1 - P(A')$","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1134},"LeftTop":{"X":219,"Y":984},"RightBottom":{"X":2437,"Y":1134},"RightTop":{"X":2437,"Y":984}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"● When events are independent of each other, the probability of all of the events occurring is equal to a product of the probabilities of each of the events occurring","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1390},"LeftTop":{"X":219,"Y":1164},"RightBottom":{"X":2549,"Y":1390},"RightTop":{"X":2549,"Y":1164}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"● $P(A')$ can be described as 23 independent events","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1493},"LeftTop":{"X":219,"Y":1418},"RightBottom":{"X":1800,"Y":1493},"RightTop":{"X":1800,"Y":1418}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"formula","Text":"$$\\bullet P(A') = P(1) \\times P(2) \\times P(3) \\times \\dots \\times P(23)$$","Level":0,"Polygon":{"LeftBottom":{"X":323,"Y":1574},"LeftTop":{"X":323,"Y":1507},"RightBottom":{"X":1340,"Y":1574},"RightTop":{"X":1340,"Y":1507}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}