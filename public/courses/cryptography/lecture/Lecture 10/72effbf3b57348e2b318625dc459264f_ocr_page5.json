{"PageNumber":5,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Hash function + Digital signature","Level":0,"Polygon":{"LeftBottom":{"X":214,"Y":305},"LeftTop":{"X":214,"Y":179},"RightBottom":{"X":1936,"Y":305},"RightTop":{"X":1936,"Y":179}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● For practical purposes, the above descriptions of the RSA digital-signature schemes are not what one would use in practice","Level":0,"Polygon":{"LeftBottom":{"X":214,"Y":616},"LeftTop":{"X":214,"Y":441},"RightBottom":{"X":2472,"Y":616},"RightTop":{"X":2472,"Y":441}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● The scheme is inefficient if the message, $M$, being signed is very long","Level":0,"Polygon":{"LeftBottom":{"X":214,"Y":738},"LeftTop":{"X":214,"Y":653},"RightBottom":{"X":2613,"Y":738},"RightTop":{"X":2613,"Y":653}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● For instance, RSA signature creation involves an encryption of the message, $M$, using a private key","Level":0,"Polygon":{"LeftBottom":{"X":323,"Y":909},"LeftTop":{"X":323,"Y":760},"RightBottom":{"X":2673,"Y":909},"RightTop":{"X":2673,"Y":760}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● For this reason, real-world digital-signature schemes are usually applied to cryptographic hashes of messages, not to actual messages","Level":0,"Polygon":{"LeftBottom":{"X":214,"Y":1120},"LeftTop":{"X":214,"Y":945},"RightBottom":{"X":2716,"Y":1120},"RightTop":{"X":2716,"Y":945}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● Moreover, signing a hash value is more efficient than signing a full message","Level":0,"Polygon":{"LeftBottom":{"X":214,"Y":1331},"LeftTop":{"X":214,"Y":1160},"RightBottom":{"X":2515,"Y":1331},"RightTop":{"X":2515,"Y":1160}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}