{"PageNumber":4,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  RSA signature: security","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":305},"LeftTop":{"X":216,"Y":185},"RightBottom":{"X":1420,"Y":305},"RightTop":{"X":1420,"Y":185}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● The nonforgeability of this scheme comes from the difficulty of breaking the RSA encryption algorithm","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":598},"LeftTop":{"X":216,"Y":436},"RightBottom":{"X":2731,"Y":598},"RightTop":{"X":2731,"Y":436}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● To forge a signature from Bob on a message, M, an attacker, Eve, would have to produce $M^d \\mod n$, without knowing d","Level":0,"Polygon":{"LeftBottom":{"X":323,"Y":755},"LeftTop":{"X":323,"Y":611},"RightBottom":{"X":2688,"Y":755},"RightTop":{"X":2688,"Y":611}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● RSA has an interesting property","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":864},"LeftTop":{"X":216,"Y":780},"RightBottom":{"X":1345,"Y":864},"RightTop":{"X":1345,"Y":780}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● For example, an attacker Eve, has two valid signatures from Bob for two messages $M_1$ and $M_2$","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1058},"LeftTop":{"X":216,"Y":888},"RightBottom":{"X":2708,"Y":1058},"RightTop":{"X":2708,"Y":888}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"$$ \\bullet S_1 = M_1^d \\text{ mod } n \\text{ and } S_2 = M_2^d \\text{ mod } n $$","Level":0,"Polygon":{"LeftBottom":{"X":323,"Y":1147},"LeftTop":{"X":323,"Y":1058},"RightBottom":{"X":1452,"Y":1147},"RightTop":{"X":1452,"Y":1058}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"● Now, Eve can produce a new signature","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1253},"LeftTop":{"X":216,"Y":1170},"RightBottom":{"X":1584,"Y":1253},"RightTop":{"X":1584,"Y":1170}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"$$ \\bullet S_1.S_2 \\mod n = (M_1.M_2)^d \\mod n $$","Level":0,"Polygon":{"LeftBottom":{"X":323,"Y":1352},"LeftTop":{"X":323,"Y":1264},"RightBottom":{"X":1374,"Y":1352},"RightTop":{"X":1374,"Y":1264}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"● This would validate as a verifiable signature from Bob on the message $M_1 M_2$","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1541},"LeftTop":{"X":216,"Y":1371},"RightBottom":{"X":2644,"Y":1541},"RightTop":{"X":2644,"Y":1371}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}