{"PageNumber":20,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Needham-Schroeder protocol","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":305},"LeftTop":{"X":216,"Y":179},"RightBottom":{"X":1783,"Y":305},"RightTop":{"X":1783,"Y":179}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● N-S uses nonces (short for \"numbers used once\")","Level":0,"Polygon":{"LeftBottom":{"X":222,"Y":527},"LeftTop":{"X":222,"Y":444},"RightBottom":{"X":1959,"Y":527},"RightTop":{"X":1959,"Y":444}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● randomly generated values included in messages","Level":0,"Polygon":{"LeftBottom":{"X":329,"Y":626},"LeftTop":{"X":329,"Y":548},"RightBottom":{"X":1803,"Y":626},"RightTop":{"X":1803,"Y":548}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● If a nonce is generated and sent by A in one step and returned by B in a later step","Level":0,"Polygon":{"LeftBottom":{"X":222,"Y":835},"LeftTop":{"X":222,"Y":661},"RightBottom":{"X":2641,"Y":835},"RightTop":{"X":2641,"Y":661}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● A knows that B's message is fresh and not a replay from an earlier exchange","Level":0,"Polygon":{"LeftBottom":{"X":329,"Y":929},"LeftTop":{"X":329,"Y":854},"RightBottom":{"X":2595,"Y":929},"RightTop":{"X":2595,"Y":854}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● We use the notation $N_a$ to denote a nonce generated by A","Level":0,"Polygon":{"LeftBottom":{"X":222,"Y":1053},"LeftTop":{"X":222,"Y":963},"RightBottom":{"X":2267,"Y":1053},"RightTop":{"X":2267,"Y":963}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"● Note that a nonce is not a timestamp","Level":0,"Polygon":{"LeftBottom":{"X":222,"Y":1167},"LeftTop":{"X":222,"Y":1084},"RightBottom":{"X":1550,"Y":1167},"RightTop":{"X":1550,"Y":1084}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"● The only assumption is that it has not been used in any earlier interchange, with high probability","Level":0,"Polygon":{"LeftBottom":{"X":222,"Y":1381},"LeftTop":{"X":222,"Y":1204},"RightBottom":{"X":2397,"Y":1381},"RightTop":{"X":2397,"Y":1204}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}