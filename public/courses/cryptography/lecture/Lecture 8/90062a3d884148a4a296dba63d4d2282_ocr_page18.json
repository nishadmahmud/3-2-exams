{"PageNumber":18,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  RSA Determinism","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":299},"LeftTop":{"X":216,"Y":187},"RightBottom":{"X":1124,"Y":299},"RightTop":{"X":1124,"Y":187}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● We must take some care in how we use the RSA cryptosystem, however, because of its deterministic nature","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":616},"LeftTop":{"X":216,"Y":446},"RightBottom":{"X":2728,"Y":616},"RightTop":{"X":2728,"Y":446}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● For example, suppose we use the RSA algorithm to encrypt two plaintext messages, $M_1$ and $M_2$, into the respective ciphertexts, $C_1$ and $C_2$, using the same public key","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":922},"LeftTop":{"X":216,"Y":655},"RightBottom":{"X":2745,"Y":922},"RightTop":{"X":2745,"Y":655}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● Because RSA is deterministic, we know that, in this case, if $C_1 = C_2$, then $M_1 = M_2$","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1139},"LeftTop":{"X":216,"Y":955},"RightBottom":{"X":2690,"Y":1139},"RightTop":{"X":2690,"Y":955}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● Unfortunately, this fact could allow a cryptanalyst to infer information from ciphertexts encrypted from supposedly different plaintexts","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1347},"LeftTop":{"X":216,"Y":1169},"RightBottom":{"X":2644,"Y":1347},"RightTop":{"X":2644,"Y":1169}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● There is an alternative cryptosystem which can handle this issue","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1463},"LeftTop":{"X":216,"Y":1382},"RightBottom":{"X":2457,"Y":1463},"RightTop":{"X":2457,"Y":1382}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}