\bmod 13 = 3 \\qquad 13 \\bmod 13 = 0 \\qquad -1 \\bmod 13 = 12 $$","Level":0,"Polygon":{"LeftBottom":{"X":320,"Y":989},"LeftTop":{"X":320,"Y":921},"RightBottom":{"X":2178,"Y":989},"RightTop":{"X":2178,"Y":921}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"$$\\bullet 29 = 3 + 2 \\times 13 \\quad 13 = 0 + 1 \\times 13 \\quad -1 = 12 + (-1) \\times 13$$","Level":0,"Polygon":{"LeftBottom":{"X":320,"Y":1081},"LeftTop":{"X":320,"Y":1003},"RightBottom":{"X":2238,"Y":1081},"RightTop":{"X":2238,"Y":1003}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"● Modulo and GCD","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1178},"LeftTop":{"X":216,"Y":1102},"RightBottom":{"X":853,"Y":1178},"RightTop":{"X":853,"Y":1102}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"• gcd(a, b) = gcd(b, a mod b)","Level":0,"Polygon":{"LeftBottom":{"X":320,"Y":1275},"LeftTop":{"X":320,"Y":1196},"RightBottom":{"X":1158,"Y":1275},"RightTop":{"X":1158,"Y":1196}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"● Example:","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1381},"LeftTop":{"X":216,"Y":1296},"RightBottom":{"X":579,"Y":1381},"RightTop":{"X":579,"Y":1296}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"$$ \\bullet \\text{gcd}(21, 12) = 3 \\text{ gcd}(12, 21 \\text{ mod } 12) = \\text{gcd}(12, 9) = 3 $$","Level":0,"Polygon":{"LeftBottom":{"X":320,"Y":1468},"LeftTop":{"X":320,"Y":1392},"RightBottom":{"X":1887,"Y":1468},"RightTop":{"X":1887,"Y":1392}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}