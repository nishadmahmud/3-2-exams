{"PageNumber":17,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  One-Time Pads","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":295},"LeftTop":{"X":216,"Y":190},"RightBottom":{"X":1023,"Y":295},"RightTop":{"X":1023,"Y":190}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● There is one type of substitution cipher that is absolutely unbreakable","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":527},"LeftTop":{"X":216,"Y":441},"RightBottom":{"X":2653,"Y":527},"RightTop":{"X":2653,"Y":441}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● The one-time pad was invented in 1917 by Joseph Mauborgne and Gilbert Vernam","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":733},"LeftTop":{"X":216,"Y":563},"RightBottom":{"X":2541,"Y":733},"RightTop":{"X":2541,"Y":563}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● We use a block of shift keys, $(k_1, k_2, \\dots, k_n)$ to encrypt a plaintext, M, of length n, with each shift key being chosen uniformly at random","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":951},"LeftTop":{"X":216,"Y":778},"RightBottom":{"X":2630,"Y":951},"RightTop":{"X":2630,"Y":778}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● Since each shift is random, every ciphertext is equally likely for any plaintext","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1160},"LeftTop":{"X":216,"Y":984},"RightBottom":{"X":2544,"Y":1160},"RightTop":{"X":2544,"Y":984}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}