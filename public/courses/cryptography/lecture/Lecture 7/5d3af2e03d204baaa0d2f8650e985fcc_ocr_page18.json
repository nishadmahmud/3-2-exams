{"PageNumber":18,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  AES – Key Expansion","Level":0,"Polygon":{"LeftBottom":{"X":211,"Y":308},"LeftTop":{"X":211,"Y":190},"RightBottom":{"X":1302,"Y":308},"RightTop":{"X":1302,"Y":190}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● The first four bytes of the encryption key constitute the word $w_0$, the next four bytes the word $w_1$, and so on","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":636},"LeftTop":{"X":219,"Y":435},"RightBottom":{"X":1752,"Y":636},"RightTop":{"X":1752,"Y":435}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● The algorithm subsequently expands the words $[w_0, w_1, w_2, w_3]$ into a 44-word key schedule that can be labelled $w_0, w_1, w_2, w_3, \\dots, w_{43}$","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":893},"LeftTop":{"X":219,"Y":673},"RightBottom":{"X":1760,"Y":893},"RightTop":{"X":1760,"Y":673}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● Of these, the words $[w_0', w_1, w_2, w_3]$ are bitwise XOR'ed with the input block before the round-based processing begins","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1115},"LeftTop":{"X":219,"Y":906},"RightBottom":{"X":1636,"Y":1115},"RightTop":{"X":1636,"Y":906}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● The remaining 40 words of the key schedule are used four words at a time in each of the 10 rounds","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1277},"LeftTop":{"X":219,"Y":1141},"RightBottom":{"X":1731,"Y":1277},"RightTop":{"X":1731,"Y":1141}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● The above two statements are also true for decryption in reverse order","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1454},"LeftTop":{"X":219,"Y":1309},"RightBottom":{"X":1515,"Y":1454},"RightTop":{"X":1515,"Y":1309}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"formula","Text":"$$ \\begin{bmatrix} k_0 & k_4 & k_8 & k_{12} \\\\ k_1 & k_5 & k_9 & k_{13} \\\\ k_2 & k_6 & k_{10} & k_{14} \\\\ k_3 & k_7 & k_{11} & k_{15} \\end{bmatrix} $$","Level":0,"Polygon":{"LeftBottom":{"X":1973,"Y":861},"LeftTop":{"X":1973,"Y":511},"RightBottom":{"X":2469,"Y":861},"RightTop":{"X":2469,"Y":511}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"formula","Text":"$$ \\begin{array}{c} \\downarrow \\\\ [w_0 \\ w_1 \\ w_2 \\ w_3] \\end{array} $$","Level":0,"Polygon":{"LeftBottom":{"X":1973,"Y":1215},"LeftTop":{"X":1973,"Y":950},"RightBottom":{"X":2469,"Y":1215},"RightTop":{"X":2469,"Y":950}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}