{"PageNumber":13,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  AES – MixColumns Step","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":308},"LeftTop":{"X":216,"Y":195},"RightBottom":{"X":1475,"Y":308},"RightTop":{"X":1475,"Y":195}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● The MixColumns Step mixes up the information in each column of the $4 \\times 4$ matrix output from the ShiftRows step","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":567},"LeftTop":{"X":216,"Y":427},"RightBottom":{"X":2650,"Y":567},"RightTop":{"X":2650,"Y":427}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● It does this mixing by applying what amounts to a Hill-cipher matrix-multiplication transformation applied to each column, using the $GF(2^8)$ number system","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":801},"LeftTop":{"X":216,"Y":589},"RightBottom":{"X":2428,"Y":801},"RightTop":{"X":2428,"Y":589}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● In other words, this step replaces each byte of a column by a function of all the bytes in the same column","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":953},"LeftTop":{"X":216,"Y":817},"RightBottom":{"X":2644,"Y":953},"RightTop":{"X":2644,"Y":817}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● More precisely, each byte in a column is replaced by two times that byte, plus three times the next byte, plus the byte that comes next, plus the byte that follows","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1185},"LeftTop":{"X":216,"Y":977},"RightBottom":{"X":2613,"Y":1185},"RightTop":{"X":2613,"Y":977}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}