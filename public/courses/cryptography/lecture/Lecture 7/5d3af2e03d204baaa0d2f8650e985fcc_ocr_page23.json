{"PageNumber":23,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"Discard_type","Text":"#  AES – Key Expansion","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":313},"LeftTop":{"X":216,"Y":192},"RightBottom":{"X":1302,"Y":313},"RightTop":{"X":1302,"Y":192}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● The round constant for the $i^{th}$ round is denoted $Rcon[i]$","Level":0,"Polygon":{"LeftBottom":{"X":225,"Y":522},"LeftTop":{"X":225,"Y":427},"RightBottom":{"X":2126,"Y":522},"RightTop":{"X":2126,"Y":427}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"• Since, by specification, the three rightmost bytes of the round constant are zero, we can write it as shown below","Level":0,"Polygon":{"LeftBottom":{"X":225,"Y":707},"LeftTop":{"X":225,"Y":546},"RightBottom":{"X":2376,"Y":707},"RightTop":{"X":2376,"Y":546}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"• Rcon[i] = (RC[i], 0x00, 0x00, 0x00)","Level":0,"Polygon":{"LeftBottom":{"X":329,"Y":799},"LeftTop":{"X":329,"Y":720},"RightBottom":{"X":1360,"Y":799},"RightTop":{"X":1360,"Y":720}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● The only non-zero byte in the round constants, RC[i], obeys the following recursion:","Level":0,"Polygon":{"LeftBottom":{"X":225,"Y":989},"LeftTop":{"X":225,"Y":822},"RightBottom":{"X":2411,"Y":989},"RightTop":{"X":2411,"Y":822}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"formula","Text":"$$ \\begin{array}{lclcl} RC[1]&=&0\\mathbf{x}01\\\\ RC[j]&=&0\\mathbf{x}02\\times RC[j-1]\\end{array} $$","Level":0,"Polygon":{"LeftBottom":{"X":784,"Y":1199},"LeftTop":{"X":784,"Y":1015},"Ri