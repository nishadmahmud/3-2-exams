{"PageNumber":11,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  AES – ShiftRows Step","Level":0,"Polygon":{"LeftBottom":{"X":211,"Y":308},"LeftTop":{"X":211,"Y":187},"RightBottom":{"X":1343,"Y":308},"RightTop":{"X":1343,"Y":187}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● The ShiftRows step is a simple permutation, which has the effect of mixing up the bytes in each row of the $4 \\times 4$ matrix output from the SubBytes step","Level":0,"Polygon":{"LeftBottom":{"X":222,"Y":713},"LeftTop":{"X":222,"Y":446},"RightBottom":{"X":2567,"Y":713},"RightTop":{"X":2567,"Y":446}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● The permutation amounts to a cyclical shift of each row of the $4 \\times 4$ matrix so that the first row is shifted left by 0, the second is shifted left by 1, the third is shifted left by 2, and the fourth is shifted left by 3, as follows:","Level":0,"Polygon":{"LeftBottom":{"X":222,"Y":1100},"LeftTop":{"X":222,"Y":749},"RightBottom":{"X":2601,"Y":1100},"RightTop":{"X":2601,"Y":749}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"formula","Text":"$$ \\begin{bmatrix} b_{0,0} & b_{0,1} & b_{0,2} & b_{0,3} \\\\ b_{1,0} & b_{1,1} & b_{1,2} & b_{1,3} \\\\ b_{2,0} & b_{2,1} & b_{2,2} & b_{2,3} \\\\ b_{3,0} & b_{3,1} & b_{3,2} & b_{3,3} \\end{bmatrix} \\quad \\rightarrow \\quad \\begin{bmatrix} b_{0,0} & b_{0,1} & b_{0,2} & b_{0,3} \\\\ b_{1,1} & b_{1,2} & b_{1,3} & b_{1,0} \\\\ b_{2,2} & b_{2,3} & b_{2,0} & b_{2,1} \\\\ b_{3,3} & b_{3,0} & b_{3,1} & b_{3,2} \\end{bmatrix} \\\\ = \\quad \\begin{bmatrix} c_{0,0} & c_{0,1} & c_{0,2} & c_{0,3} \\\\ c_{1,0} & c_{1,1} & c_{1,2} & c_{1,3} \\\\ c_{2,0} & c_{2,1} & c_{2,2} & c_{2,3} \\\\ c_{3,0} & c_{3,1} & c_{3,2} & c_{3,3} \\end{bmatrix} $$","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":1570},"LeftTop":{"X":945,"Y":1078},"RightBottom":{"X":2060,"Y":1570},"RightTop":{"X":2060,"Y":1078}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}