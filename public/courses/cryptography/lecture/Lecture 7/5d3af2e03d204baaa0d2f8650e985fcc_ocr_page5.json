{"PageNumber":5,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  AES","Level":0,"Polygon":{"LeftBottom":{"X":208,"Y":292},"LeftTop":{"X":208,"Y":192},"RightBottom":{"X":421,"Y":292},"RightTop":{"X":421,"Y":192}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● To provide some structure to the 128-bit blocks it operates on, the AES algorithm views each such block, starting with the 128-bit block of plaintext, as 16 bytes of 8 bits each","Level":0,"Polygon":{"LeftBottom":{"X":225,"Y":665},"LeftTop":{"X":225,"Y":435},"RightBottom":{"X":2495,"Y":665},"RightTop":{"X":2495,"Y":435}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"formula","Text":"$$ \\left(a_{0,0},a_{1,0},a_{2,0},a_{3,0},a_{0,1},a_{1,1},a_{2,1},a_{3,1},a_{0,2},a_{1,2},a_{2,2},a_{3,2},a_{0,3},a_{1,3},a_{2,3},a_{3,3}\\right), $$","Level":0,"Polygon":{"LeftBottom":{"X":660,"Y":764},"LeftTop":{"X":660,"Y":692},"RightBottom":{"X":2232,"Y":764},"RightTop":{"X":2232,"Y":692}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● This is arranged in column-major order into a $4 \\times 4$ matrix as follows:","Level":0,"Polygon":{"LeftBottom":{"X":225,"Y":870},"LeftTop":{"X":225,"Y":793},"RightBottom":{"X":2428,"Y":870},"RightTop":{"X":2428,"Y":793}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"formula","Text":"$$ \\begin{bmatrix} a_{0,0}& a_{0,1}& a_{0,2}& a_{0,3}\\\\ a_{1,0}& a_{1,1}& a_{1,2}& a_{1,3}\\\\ a_{2,0}& a_{2,1}& a_{2,2}& a_{2,3}\\\\ a_{3,0}& a_{3,1}& a_{3,2}& a_{3,3}\\end{bmatrix} \\begin{bmatrix} byte_0 & byte_4 & byte_8 & byte_{12} \\\\ byte_1 & byte_5 & byte_9 & byte_{13} \\\\ byte_2 & byte_6 & byte_{10} & byte_{14} \\\\ byte_3 & byte_7 & byte_{11} & byte_{15} \\end{bmatrix} $$","Level":0,"Polygon":{"LeftBottom":{"X":513,"Y":1194},"LeftTop":{"X":513,"Y":888},"RightBottom":{"X":1936,"Y":1194},"RightTop":{"X":1936,"Y":888}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"• AES also has the notion of a word consisting of four bytes, that is 32 bits.","Level":0,"Polygon":{"LeftBottom":{"X":225,"Y":1293},"LeftTop":{"X":225,"Y":1212},"RightBottom":{"X":2529,"Y":1293},"RightTop":{"X":2529,"Y":1212}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"● Therefore, each column of the state array is a word, as is each row","Level":0,"Polygon":{"LeftBottom":{"X":225,"Y":1395},"LeftTop":{"X":225,"Y":1319},"RightBottom":{"X":2356,"Y":1395},"RightTop":{"X":2356,"Y":1319}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"● Each round of processing works on the input state array and produces an output state array","Level":0,"Polygon":{"LeftBottom":{"X":225,"Y":1578},"LeftTop":{"X":225,"Y":1423},"RightBottom":{"X":2564,"Y":1578},"RightTop":{"X":2564,"Y":1423}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}