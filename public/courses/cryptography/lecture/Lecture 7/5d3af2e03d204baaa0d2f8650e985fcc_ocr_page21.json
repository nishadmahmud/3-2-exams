{"PageNumber":21,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"Discard_type","Text":"#  AES – Key Expansion","Level":0,"Polygon":{"LeftBottom":{"X":211,"Y":308},"LeftTop":{"X":211,"Y":192},"RightBottom":{"X":1302,"Y":308},"RightTop":{"X":1302,"Y":192}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● Except for the first word in a new 4-word grouping, each word is an XOR of the previous word and the corresponding word in the previous 4-word grouping.","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":636},"LeftTop":{"X":216,"Y":427},"RightBottom":{"X":2633,"Y":636},"RightTop":{"X":2633,"Y":427}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"formula","Text":"$$ \\begin{array}{lcl} w_{i+5}&=&w_{i+4}\\quad\\textcircled{21}\\quad w_{i+1}\\\\ w_{i+6}&=&w_{i+5}\\quad\\otimes\\quad w_{i+2}\\\\ w_{i+7}&=&w_{i+6}\\quad\\otimes\\quad w_{i+3}\\end{array} $$","Level":0,"Polygon":{"LeftBottom":{"X":936,"Y":867},"LeftTop":{"X":936,"Y":605},"RightBottom":{"X":1659,"Y":867},"RightTop":{"X":1659,"Y":605}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● So now we only need to figure out $w_{i+4}$","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1023},"LeftTop":{"X":216,"Y":940},"RightBottom":{"X":1495,"Y":1023},"RightTop":{"X":1495,"Y":940}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● This is the beginning word of each 4-word grouping in the key expansion","Level":0,"Polygon":{"LeftBottom":{"X":323,"Y":1094},"LeftTop":{"X":323,"Y":1023},"RightBottom":{"X":2310,"Y":1094},"RightTop":{"X":2310,"Y":1023}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● The beginning word of each round key is obtained by:","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1185},"LeftTop":{"X":216,"Y":1104},"RightBottom":{"X":1962,"Y":1185},"RightTop":{"X":1962,"Y":1104}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"$\\bullet w_{i+4}=w_i$ ![](677,1208,737,1264)  $g(w_i+3)$","Level":0,"Polygon":{"LeftBottom":{"X":323,"Y":1274},"LeftTop":{"X":323,"Y":1201},"RightBottom":{"X":1020,"Y":1274},"RightTop":{"X":1020,"Y":1201}},"InsetImageName":"","Elements":null,"ImagePath":"images/1e63564bad9444791d9586d7bbc8cc04-image.png","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"● Here, ![](544,1281,600,1337)  signifies an XOR operation","Level":0,"Polygon":{"LeftBottom":{"X":323,"Y":1343},"LeftTop":{"X":323,"Y":1277},"RightBottom":{"X":1308,"Y":1343},"RightTop":{"X":1308,"Y":1277}},"InsetImageName":"","Elements":null,"ImagePath":"images/4a679a735343f2ec263c4ac6217cf3db-image.png","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"● That is, the first word of the new 4-word grouping is to be obtained by XOR'ing the first word of the last grouping with what is returned by applying a function g() to the last word of the previous 4-word grouping","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1572},"LeftTop":{"X":216,"Y":1361},"RightBottom":{"X":2535,"Y":1572},"RightTop":{"X":2535,"Y":1361}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}