{"PageNumber":9,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  PING Flood","Level":0,"Polygon":{"LeftBottom":{"X":214,"Y":289},"LeftTop":{"X":214,"Y":179},"RightBottom":{"X":807,"Y":289},"RightTop":{"X":807,"Y":179}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● In a ping flood attack, a powerful machine can perform a DoS attack on a weaker machine","Level":0,"Polygon":{"LeftBottom":{"X":214,"Y":611},"LeftTop":{"X":214,"Y":441},"RightBottom":{"X":2595,"Y":611},"RightTop":{"X":2595,"Y":441}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● To carry out the attack, a powerful machine sends a massive amounts of PING echo requests to a single victim server with the following two conditions:","Level":0,"Polygon":{"LeftBottom":{"X":214,"Y":913},"LeftTop":{"X":214,"Y":653},"RightBottom":{"X":2641,"Y":913},"RightTop":{"X":2641,"Y":653}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● The attacker can create many more ping requests than the victim can process, and","Level":0,"Polygon":{"LeftBottom":{"X":320,"Y":1081},"LeftTop":{"X":320,"Y":940},"RightBottom":{"X":2650,"Y":1081},"RightTop":{"X":2650,"Y":940}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● The victim has enough network bandwidth to receive all these requests","Level":0,"Polygon":{"LeftBottom":{"X":320,"Y":1185},"LeftTop":{"X":320,"Y":1109},"RightBottom":{"X":2466,"Y":1185},"RightTop":{"X":2466,"Y":1109}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● If these happen, the victim server will be overwhelmed with the traffic and start to drop legitimate connections","Level":0,"Polygon":{"LeftBottom":{"X":214,"Y":1395},"LeftTop":{"X":214,"Y":1219},"RightBottom":{"X":2451,"Y":1395},"RightTop":{"X":2451,"Y":1219}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}