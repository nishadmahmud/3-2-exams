{"PageNumber":23,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  DNS Cache Poisoning","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":308},"LeftTop":{"X":219,"Y":187},"RightBottom":{"X":1331,"Y":308},"RightTop":{"X":1331,"Y":187}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"DNS cache poisoning corrupts a DNS server's cache with bogus data such as a rogue address, opening the door to data theft and other threats.","Level":0,"Polygon":{"LeftBottom":{"X":375,"Y":668},"LeftTop":{"X":375,"Y":425},"RightBottom":{"X":1259,"Y":668},"RightTop":{"X":1259,"Y":425}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"1. Attacker queries a recursive name server for a subdomain that doesn't exist (e.g. q0001.bankofamerica.com)","Level":0,"Polygon":{"LeftBottom":{"X":401,"Y":864},"LeftTop":{"X":401,"Y":702},"RightBottom":{"X":1294,"Y":864},"RightTop":{"X":1294,"Y":702}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"2. The recursive server does not have the IP address and queries a bankofamerica.com name server","Level":0,"Polygon":{"LeftBottom":{"X":395,"Y":1050},"LeftTop":{"X":395,"Y":888},"RightBottom":{"X":1357,"Y":1050},"RightTop":{"X":1357,"Y":888}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"3. Before bankofamerica.com name server can send NXDOMAIN response, attacker sends lots of spoofed responses that looks like they are coming from a legitimate bankofamerica.com server","Level":0,"Polygon":{"LeftBottom":{"X":395,"Y":1353},"LeftTop":{"X":395,"Y":1078},"RightBottom":{"X":1351,"Y":1353},"RightTop":{"X":1351,"Y":1078}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"Spoofed responses map www.bankofamerica.com to IP address of a server controlled by attacker","Level":0,"Polygon":{"LeftBottom":{"X":1498,"Y":647},"LeftTop":{"X":1498,"Y":425},"RightBottom":{"X":2037,"Y":647},"RightTop":{"X":2037,"Y":425}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"4. The recursive name server accepts a spoofed response, caches the record","Level":0,"Polygon":{"LeftBottom":{"X":1443,"Y":780},"LeftTop":{"X":1443,"Y":673},"RightBottom":{"X":2287,"Y":780},"RightTop":{"X":2287,"Y":673}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"5. User queries the recursive name server for IP address of www.bankofamerica.com","Level":0,"Polygon":{"LeftBottom":{"X":1443,"Y":908},"LeftTop":{"X":1443,"Y":802},"RightBottom":{"X":2397,"Y":908},"RightTop":{"X":2397,"Y":802}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"6. The recursive name server replies to user with cached rogue IP address","Level":0,"Polygon":{"LeftBottom":{"X":1443,"Y":1045},"LeftTop":{"X":1443,"Y":935},"RightBottom":{"X":2368,"Y":1045},"RightTop":{"X":2368,"Y":935}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"7. User connects to site controlled by attacker which may look exactly like the real bank of america website","Level":0,"Polygon":{"LeftBottom":{"X":1443,"Y":1230},"LeftTop":{"X":1443,"Y":1071},"RightBottom":{"X":2411,"Y":1230},"RightTop":{"X":2411,"Y":1071}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"Impact: Logins, passwords, credit card numbers of the user can be captured","Level":0,"Polygon":{"LeftBottom":{"X":1426,"Y":1386},"LeftTop":{"X":1426,"Y":1264},"RightBottom":{"X":2313,"Y":1