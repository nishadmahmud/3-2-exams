{"PageNumber":17,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Distributed DoS (DDoS)","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":305},"LeftTop":{"X":219,"Y":182},"RightBottom":{"X":1440,"Y":305},"RightTop":{"X":1440,"Y":182}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● A denial-of-service condition can be created by using more than one attacking machine, in what is known as a distributed denial-of-service (DDOS) attack","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":707},"LeftTop":{"X":219,"Y":444},"RightBottom":{"X":2659,"Y":707},"RightTop":{"X":2659,"Y":444}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● In this attack, malicious users leverage the power of many machines (sometimes hundreds or even thousands) to direct traffic against a single web site in an attempt to create denial-of-service conditions","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1007},"LeftTop":{"X":219,"Y":751},"RightBottom":{"X":2587,"Y":1007},"RightTop":{"X":2587,"Y":751}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● Major web sites, such as Yahoo!, Amazon, and Google, have been the targets of repeated DDOS attacks","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1224},"LeftTop":{"X":219,"Y":1053},"RightBottom":{"X":2627,"Y":1224},"RightTop":{"X":2627,"Y":1053}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● Often, attackers carry out DDOS attacks by using botnets—large networks of machines that have been compromised and are controllable remotely","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1520},"LeftTop":{"X":219,"Y":1264},"RightBottom":{"X":2448,"Y":1520},"RightTop":{"X":2448,"Y":1264}},"In