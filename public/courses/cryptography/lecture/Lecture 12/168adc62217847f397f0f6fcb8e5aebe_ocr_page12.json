{"PageNumber":12,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Mitigating SMURF Attack","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":305},"LeftTop":{"X":219,"Y":185},"RightBottom":{"X":1536,"Y":305},"RightTop":{"X":1536,"Y":185}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● To prevent SMURF attacks, administrators should configure hosts on their networks to ignore broadcast requests","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":616},"LeftTop":{"X":219,"Y":448},"RightBottom":{"X":2595,"Y":616},"RightTop":{"X":2595,"Y":448}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● if a server is relatively weak, it would be wise for it to ignore ping requests altogether, to avoid ping floods","Level":0,"Polygon":{"LeftBottom":{"X":326,"Y":788},"LeftTop":{"X":326,"Y":644},"RightBottom":{"X":2546,"Y":788},"RightTop":{"X":2546,"Y":644}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● In addition, routers should be configured to avoid forwarding packets directed to broadcast addresses, as this poses a security risk in that the network can be used as a ping flood amplifier","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1089},"LeftTop":{"X":219,"Y":830},"RightBottom":{"X":2636,"Y":1089},"RightTop":{"X":2636,"Y":830}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}