{"PageNumber":10,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Digital certificates","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":310},"LeftTop":{"X":216,"Y":188},"RightBottom":{"X":1176,"Y":310},"RightTop":{"X":1176,"Y":188}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● Such a statement is called digital certificates","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":527},"LeftTop":{"X":219,"Y":443},"RightBottom":{"X":1772,"Y":527},"RightTop":{"X":1772,"Y":443}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● Such a trusted authority is called a Certificate Authority (CA)","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":650},"LeftTop":{"X":219,"Y":563},"RightBottom":{"X":2313,"Y":650},"RightTop":{"X":2313,"Y":563}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"●Since the digital certificate is a strong evidence of the authenticity of Bob's public key, Alice can trust it even if it comes from an unsigned email message or is posted on a third-party web site","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":953},"LeftTop":{"X":219,"Y":689},"RightBottom":{"X":2607,"Y":953},"RightTop":{"X":2607,"Y":689}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● However, Alice also needs to trust the public key of Cas","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1071},"LeftTop":{"X":219,"Y":987},"RightBottom":{"X":2143,"Y":1071},"RightTop":{"X":2143,"Y":987}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● This creates a circular problem","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1190},"LeftTop":{"X":219,"Y":1109},"RightBottom":{"X":1308,"Y":1190},"RightTop":{"X":1308,"Y":1109}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"● Solution, embed the public keys of the CAs in the OS/Browser","Level":0,"Polygon":{"LeftBottom":{"X":335,"Y":1288},"LeftTop":{"X":335,"Y":1212},"RightBottom":{"X":2169,"Y":1288},"RightTop":{"X":2169,"Y":1212}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"● We will study the protocol for validating digital certificates when we study web security","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1499},"LeftTop":{"X":219,"Y":1322},"RightBottom":{"X":2581,"Y":1499},"RightTop":{"X":2581,"Y":1322}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}