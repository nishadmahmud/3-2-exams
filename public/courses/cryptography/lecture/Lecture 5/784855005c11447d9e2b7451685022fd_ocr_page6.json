{"PageNumber":6,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Message Authentication Code (MAC)","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":310},"LeftTop":{"X":216,"Y":187},"RightBottom":{"X":2184,"Y":310},"RightTop":{"X":2184,"Y":187}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● A cryptographic hash function $h$ can be used in conjunction with a secret key shared by two parties to provide integrity protection to messages exchanged over an insecure channel, much like a digital signature","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":661},"LeftTop":{"X":216,"Y":435},"RightBottom":{"X":2564,"Y":661},"RightTop":{"X":2564,"Y":435}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● Suppose Alice and Bob share a secret key $K$","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":767},"LeftTop":{"X":216,"Y":691},"RightBottom":{"X":1639,"Y":767},"RightTop":{"X":1639,"Y":691}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● When Alice wants to send a message M to Bob, she computes the hash value of the key K concatenated with message M: A = h(K | M)","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":945},"LeftTop":{"X":216,"Y":794},"RightBottom":{"X":2515,"Y":945},"RightTop":{"X":2515,"Y":794}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● A is called the MAC","Level":0,"Polygon":{"LeftBottom":{"X":323,"Y":1023},"LeftTop":{"X":323,"Y":963},"RightBottom":{"X":902,"Y":1023},"RightTop":{"X":902,"Y":963}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● Alice sends the pair $(M,A)$ to Bob","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1133},"LeftTop":{"X":216,"Y":1053},"RightBottom":{"X":1308,"Y":1133},"RightTop":{"X":1308,"Y":1053}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"● Let's assume what Bob receives (M', A)","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1235},"LeftTop":{"X":216,"Y":1156},"RightBottom":{"X":1498,"Y":1235},"RightTop":{"X":1498,"Y":1156}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"● Alice computes $A' = h(k||M')$, if $A = A'$, Bob is assured that","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":1343},"LeftTop":{"X":216,"Y":1258},"RightBottom":{"X":2192,"Y":1343},"RightTop":{"X":2192,"Y":1258}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"● the message is sent by Alice, thus guaranteeing authenticity","Level":0,"Polygon":{"LeftBottom":{"X":323,"Y":1423},"LeftTop":{"X":323,"Y":1355},"RightBottom":{"X":1979,"Y":1423},"RightTop":{"X":1979,"Y":1355}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"● and the message has not been altered during transmission and hence guaranteeing integrity","Level":0,"Polygon":{"LeftBottom":{"X":323,"Y":1564},"LeftTop":{"X":323,"Y":1433},"RightBottom":{"X":2610,"Y":1564},"RightTop":{"X":2610,"Y":1433}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}