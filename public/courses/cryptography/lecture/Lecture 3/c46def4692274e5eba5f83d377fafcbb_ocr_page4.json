{"PageNumber":4,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Fail-safe defaults","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":308},"LeftTop":{"X":216,"Y":188},"RightBottom":{"X":1115,"Y":308},"RightTop":{"X":1115,"Y":188}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"●This principle states that the default configuration of a system should have a conservative protection scheme","Level":0,"Polygon":{"LeftBottom":{"X":222,"Y":600},"LeftTop":{"X":222,"Y":440},"RightBottom":{"X":2621,"Y":600},"RightTop":{"X":2621,"Y":440}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● For example, when adding a new user to an operating system, the default group of the user should have minimal access rights to files and services","Level":0,"Polygon":{"LeftBottom":{"X":222,"Y":864},"LeftTop":{"X":222,"Y":631},"RightBottom":{"X":2546,"Y":864},"RightTop":{"X":2546,"Y":631}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● Unfortunately, operating systems and applications often have default options that favour usability over security","Level":0,"Polygon":{"LeftBottom":{"X":222,"Y":1066},"LeftTop":{"X":222,"Y":901},"RightBottom":{"X":2621,"Y":1066},"RightTop":{"X":2621,"Y":901}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"●This has been historically the case for a number of popular applications, such as web browsers that allow the execution of code downloaded from the web server","Level":0,"Polygon":{"LeftBottom":{"X":222,"Y":1331},"LeftTop":{"X":222,"Y":1092},"RightBottom":{"X":2595,"Y":1331},"RightTop":{"X":2595,"Y":1092}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}