{"PageNumber":24,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Role Based Access Control (RBAC)","Level":0,"Polygon":{"LeftBottom":{"X":214,"Y":315},"LeftTop":{"X":214,"Y":182},"RightBottom":{"X":2016,"Y":315},"RightTop":{"X":2016,"Y":182}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● Define roles and then specify access control rights for these roles, rather than for subjects directly","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":608},"LeftTop":{"X":219,"Y":427},"RightBottom":{"X":1469,"Y":608},"RightTop":{"X":1469,"Y":427}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● For example, a file system for a university computer science department could have roles for “faculty,” “student,” “administrative personnel,” “administrative manager,” “backup agent,” “lab manager,” “system administrator,” etc.","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":960},"LeftTop":{"X":219,"Y":629},"RightBottom":{"X":1512,"Y":960},"RightTop":{"X":1512,"Y":629}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● Each role is granted the access rights that are appropriate for the class of users associated with that role","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1157},"LeftTop":{"X":219,"Y":984},"RightBottom":{"X":1464,"Y":1157},"RightTop":{"X":1464,"Y":984}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● Then assign a user to the corresponding role","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1241},"LeftTop":{"X":219,"Y":1177},"RightBottom":{"X":1440,"Y":1241},"RightTop":{"X":1440,"Y":1177}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● Such role can take advantage of the concept of inheritance:","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1376},"LeftTop":{"X":219,"Y":1261},"RightBottom":{"X":1507,"Y":1376},"RightTop":{"X":1507,"Y":1261}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"● if a role R1 is above role R2 in the hierarchy, then R1 inherits the access rights of R2","Level":0,"Polygon":{"LeftBottom":{"X":326,"Y":1494},"LeftTop":{"X":326,"Y":1387},"RightBottom":{"X":1489,"Y":1494},"RightTop":{"X":1489,"Y":1387}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":1625,"Y":1201},"LeftTop":{"X":1625,"Y":501},"RightBottom":{"X":2745,"Y":1201},"RightTop":{"X":2745,"Y":501}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"graph TD     A[Department Chair] --> B[Administrative Manager]     Lab Manager/System Administrator]     Administrator]     Undergraduate TA/Graduate TA]     Accountant/Secretary]     Lab Technician/Backup Agent]     Undergraduate Student/Graduate Student]     Administrative Personnel]     Technical Personnel]     Department Member]","Level":0,"Polygon":{"LeftBottom":{"X":1625,"Y":1201},"LeftTop":{"X":1625,"Y":501},"RightBottom":{"X":2745,"Y":1201},"RightTop":{"X":2745,"Y":501}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/d148a7580b060a2e0a1645d129dbb26a-image.png","group_id":-1,"group_type":""}]}