{"PageNumber":9,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Least common mechanism","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":305},"LeftTop":{"X":219,"Y":190},"RightBottom":{"X":1639,"Y":305},"RightTop":{"X":1639,"Y":190}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"●In systems with multiple users, mechanisms allowing resources to be shared by more than one user should be minimised","Level":0,"Polygon":{"LeftBottom":{"X":231,"Y":621},"LeftTop":{"X":231,"Y":451},"RightBottom":{"X":2610,"Y":621},"RightTop":{"X":2610,"Y":451}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● For example, if a file or application needs to be accessed by more than one user, then these users should have separate channels by which to access these resources, to prevent unforeseen consequences that could cause security problems","Level":0,"Polygon":{"LeftBottom":{"X":231,"Y":1015},"LeftTop":{"X":231,"Y":660},"RightBottom":{"X":2659,"Y":1015},"RightTop":{"X":2659,"Y":660}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}