{"PageNumber":23,"Angle":0,"RotatedAngle":0,"Height":1215,"Width":2160,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  The Hill Algorithm","Level":0,"Polygon":{"LeftBottom":{"X":52,"Y":109},"LeftTop":{"X":52,"Y":32},"RightBottom":{"X":1117,"Y":109},"RightTop":{"X":1117,"Y":32}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"Decryption requires $K^{-1}$, the inverse matrix $K$.","Level":0,"Polygon":{"LeftBottom":{"X":89,"Y":190},"LeftTop":{"X":89,"Y":134},"RightBottom":{"X":2046,"Y":190},"RightTop":{"X":2046,"Y":134}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"formula","Text":"$$K^{-1} = \\frac{1}{\\det K} \\times \\text{Adj K}$$","Level":0,"Polygon":{"LeftBottom":{"X":96,"Y":302},"LeftTop":{"X":96,"Y":202},"RightBottom":{"X":949,"Y":302},"RightTop":{"X":949,"Y":202}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"title","Text":"##  To find Det K, Adj K The Hill Algorithm","Level":0,"Polygon":{"LeftBottom":{"X":50,"Y":491},"LeftTop":{"X":50,"Y":370},"RightBottom":{"X":990,"Y":491},"RightTop":{"X":990,"Y":370}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"To find the determinant of K: $\\begin{pmatrix} 17 & 17 & 5 \\\\ 21 & 18 & 21 \\\\ 2 & 2 & 19 \\end{pmatrix}$","Level":0,"Polygon":{"LeftBottom":{"X":65,"Y":620},"LeftTop":{"X":65,"Y":483},"RightBottom":{"X":1348,"Y":620},"RightTop":{"X":1348,"Y":483}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"code","Text":"$$ \\begin{aligned} \\text{Det}\\begin{pmatrix} 17 & 17 & 5 \\\\ 21 & 18 & 21 \\\\ 2 & 2 & 19 \\end{pmatrix} \\text{ mod } 26 \\\\ &= 17(18 \\times 19 - 2 \\times 21) - 17(19 \\times 21 - 2 \\times 21) + 5(2 \\times 21 - 2 \\times 18) \\text{ mod } 26 \\\\ &= 17(342 - 42) - 17(399 - 42) + 5(42 - 36) \\text{ mod } 26 \\\\ &= 17(300) - 17(357) + 5(6) \\text{ mod } 26 \\\\ &= 5100 - 6069 + 30 \\text{ mod } 26 \\\\ &= -939 \\text{ mod } 26 \\\\ &= -3 \\text{ mod } 26 = 23 \\end{aligned} $$","Level":0,"Polygon":{"LeftBottom":{"X":65,"Y":1123},"LeftTop":{"X":65,"Y":629},"RightBottom":{"X":2037,"Y":1123},"RightTop":{"X":2037,"Y":629}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"footer","Text":"Activate WindowGo to Settings to activ","Level":0,"Polygon":{"LeftBottom":{"X":1925,"Y":1124},"LeftTop":{"X":1925,"Y":1088},"RightBottom":{"X":2111,"Y":1124},"RightTop":{"X":2111,"Y":1088}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}