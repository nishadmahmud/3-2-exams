{"PageNumber":36,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Mitigating IP Spoofing","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":305},"LeftTop":{"X":219,"Y":185},"RightBottom":{"X":1383,"Y":305},"RightTop":{"X":1383,"Y":185}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● Unfortunately, IP spoofing cannot be prevented!","Level":0,"Polygon":{"LeftBottom":{"X":211,"Y":509},"LeftTop":{"X":211,"Y":427},"RightBottom":{"X":1800,"Y":509},"RightTop":{"X":1800,"Y":427}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● But they can be handled in a different way!","Level":0,"Polygon":{"LeftBottom":{"X":317,"Y":580},"LeftTop":{"X":317,"Y":509},"RightBottom":{"X":1536,"Y":580},"RightTop":{"X":1536,"Y":509}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● Borders routers connecting two sub-nets, can be configured to block any packet with the source address outside their domain","Level":0,"Polygon":{"LeftBottom":{"X":211,"Y":733},"LeftTop":{"X":211,"Y":593},"RightBottom":{"X":2578,"Y":733},"RightTop":{"X":2578,"Y":593}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● IP spoofing can be combated by implementing IP traceback techniques","Level":0,"Polygon":{"LeftBottom":{"X":211,"Y":836},"LeftTop":{"X":211,"Y":754},"RightBottom":{"X":2515,"Y":836},"RightTop":{"X":2515,"Y":754}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● IP traceback involves methods for tracing the path of a packet back to its actual source address","Level":0,"Polygon":{"LeftBottom":{"X":211,"Y":989},"LeftTop":{"X":211,"Y":851},"RightBottom":{"X":2578,"Y":989},"RightTop":{"X":2578,"Y":851}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"● Given this information, requests can then be made to the various autonomous systems along this path to block packets from this location","Level":0,"Polygon":{"LeftBottom":{"X":211,"Y":1156},"LeftTop":{"X":211,"Y":1010},"RightBottom":{"X":2544,"Y":1156},"RightTop":{"X":2544,"Y":1010}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"● The ISP controlling the actual source address can also be asked to block suspicious machines entirely until it is determined that they are clean of any malware or malicious users.","Level":0,"Polygon":{"LeftBottom":{"X":211,"Y":1381},"LeftTop":{"X":211,"Y":1172},"RightBottom":{"X":2561,"Y":1381},"RightTop":{"X":2561,"Y":1172}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}