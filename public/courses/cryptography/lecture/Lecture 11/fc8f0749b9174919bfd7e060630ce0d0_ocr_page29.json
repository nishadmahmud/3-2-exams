{"PageNumber":29,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  ARP Spoofing","Level":0,"Polygon":{"LeftBottom":{"X":208,"Y":305},"LeftTop":{"X":208,"Y":185},"RightBottom":{"X":922,"Y":305},"RightTop":{"X":922,"Y":185}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● The ARP protocol is simple and effective, but it lacks an authentication scheme","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":611},"LeftTop":{"X":219,"Y":441},"RightBottom":{"X":2143,"Y":611},"RightTop":{"X":2143,"Y":441}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● Any computer on the network could claim to have the requested IP address","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":820},"LeftTop":{"X":219,"Y":655},"RightBottom":{"X":2555,"Y":820},"RightTop":{"X":2555,"Y":655}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● In fact, any machine that receives an ARP reply, even if it was not preceded by a request, will automatically update its ARP cache with the new association","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1125},"LeftTop":{"X":219,"Y":867},"RightBottom":{"X":2572,"Y":1125},"RightTop":{"X":2572,"Y":867}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● Because of this shortcoming, it is possible for malicious parties on a LAN to perform the ARP spoofing attack","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1345},"LeftTop":{"X":219,"Y":1169},"RightBottom":{"X":2569,"Y":1345},"RightTop":{"X":2569,"Y":1169}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}