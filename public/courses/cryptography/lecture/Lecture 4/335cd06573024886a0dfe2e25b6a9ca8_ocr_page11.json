{"PageNumber":11,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Combining symmetric and public key systems","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":310},"LeftTop":{"X":216,"Y":185},"RightBottom":{"X":2633,"Y":310},"RightTop":{"X":2633,"Y":185}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● The main disadvantage of public-key cryptosystems is that they are much slower than existing symmetric encryption schemes","Level":0,"Polygon":{"LeftBottom":{"X":231,"Y":616},"LeftTop":{"X":231,"Y":449},"RightBottom":{"X":2546,"Y":616},"RightTop":{"X":2546,"Y":449}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● Hence, public-key cryptography is unsuitable for interactive sessions that use a lot of back-and-forth communication","Level":0,"Polygon":{"LeftBottom":{"X":335,"Y":783},"LeftTop":{"X":335,"Y":644},"RightBottom":{"X":2618,"Y":783},"RightTop":{"X":2618,"Y":644}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● Also, public-key cryptosystems have larger key lengths than that for symmetric cryptosystems","Level":0,"Polygon":{"LeftBottom":{"X":231,"Y":1002},"LeftTop":{"X":231,"Y":830},"RightBottom":{"X":2561,"Y":1002},"RightTop":{"X":2561,"Y":830}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● For example, RSA is commonly used with 2,048-bit keys while AES is typically used with 256-bit keys","Level":0,"Polygon":{"LeftBottom":{"X":335,"Y":1172},"LeftTop":{"X":335,"Y":1023},"RightBottom":{"X":2613,"Y":1172},"RightTop":{"X":2613,"Y":1023}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}