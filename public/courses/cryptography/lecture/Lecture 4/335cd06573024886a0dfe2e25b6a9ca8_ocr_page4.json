{"PageNumber":4,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Encryption","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":310},"LeftTop":{"X":216,"Y":192},"RightBottom":{"X":792,"Y":310},"RightTop":{"X":792,"Y":192}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● As equations:","Level":0,"Polygon":{"LeftBottom":{"X":225,"Y":503},"LeftTop":{"X":225,"Y":435},"RightBottom":{"X":663,"Y":503},"RightTop":{"X":663,"Y":435}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"formula","Text":"$$ \\bullet C = E(M), M = D(C) $$","Level":0,"Polygon":{"LeftBottom":{"X":329,"Y":567},"LeftTop":{"X":329,"Y":506},"RightBottom":{"X":839,"Y":567},"RightTop":{"X":839,"Y":506}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● The encryption and decryption algorithms are chosen so that it is infeasible for someone other than Alice and Bob to determine plaintext M from ciphertext C","Level":0,"Polygon":{"LeftBottom":{"X":225,"Y":718},"LeftTop":{"X":225,"Y":587},"RightBottom":{"X":2549,"Y":718},"RightTop":{"X":2549,"Y":587}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● Thus, ciphertext $C$ can be transmitted over an insecure channel that can be eavesdropped by an adversary","Level":0,"Polygon":{"LeftBottom":{"X":225,"Y":867},"LeftTop":{"X":225,"Y":738},"RightBottom":{"X":2428,"Y":867},"RightTop":{"X":2428,"Y":738}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● The decryption algorithm must use some secret information known to Bob, and possibly also to Alice, but no other party","Level":0,"Polygon":{"LeftBottom":{"X":225,"Y":1018},"LeftTop":{"X":225,"Y":887},"RightBottom":{"X":2569,"Y":1018},"RightTop":{"X":2569,"Y":887}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"● using an auxiliary input a secret number or string called decryption key.","Level":0,"Polygon":{"LeftBottom":{"X":329,"Y":1084},"LeftTop":{"X":329,"Y":1023},"RightBottom":{"X":2137,"Y":1084},"RightTop":{"X":2137,"Y":1023}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"● the decryption algorithm itself can be implemented by standard, publicly available software and only the decryption key needs to remain secret","Level":0,"Polygon":{"LeftBottom":{"X":329,"Y":1203},"LeftTop":{"X":329,"Y":1089},"RightBottom":{"X":2644,"Y":1203},"RightTop":{"X":2644,"Y":1089}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"● Similarly, the encryption algorithm uses as auxiliary input an encryption key, which is associated with the decryption key","Level":0,"Polygon":{"LeftBottom":{"X":225,"Y":1355},"LeftTop":{"X":225,"Y":1220},"RightBottom":{"X":2472,"Y":1355},"RightTop":{"X":2472,"Y":1220}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"● If it is feasible to derive the decryption key from the encryption key, the encryption key should be kept secret as well","Level":0,"Polygon":{"LeftBottom":{"X":225,"Y":1502},"LeftTop":{"X":225,"Y":1373},"RightBottom":{"X":2336,"Y":1502},"RightTop":{"X":2336,"Y":1373}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}