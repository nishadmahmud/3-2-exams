{"PageNumber":13,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Digital signature","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":310},"LeftTop":{"X":219,"Y":188},"RightBottom":{"X":1080,"Y":310},"RightTop":{"X":1080,"Y":188}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"● Public key crypto systems allow the reversing the order in which encryption and decryption is carried out","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":569},"LeftTop":{"X":219,"Y":427},"RightBottom":{"X":2650,"Y":569},"RightTop":{"X":2650,"Y":427}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"formula","Text":"$$ \\bullet E_{P_B}\\left(D_{S_B}(M)\\right) = M $$","Level":0,"Polygon":{"LeftBottom":{"X":323,"Y":697},"LeftTop":{"X":323,"Y":580},"RightBottom":{"X":916,"Y":697},"RightTop":{"X":916,"Y":580}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● This concept is leveraged to create digital signatures","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":789},"LeftTop":{"X":219,"Y":707},"RightBottom":{"X":1916,"Y":789},"RightTop":{"X":1916,"Y":707}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● To sign a message, M, Alice just decrypts it with her private key, $S_A$, creating $C = D_{S_A}(M)$","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":966},"LeftTop":{"X":219,"Y":799},"RightBottom":{"X":2662,"Y":966},"RightTop":{"X":2662,"Y":799}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● Anyone can encrypt this message using Alice's public key, as $M' = E_{PA}(C)$ and then compare if $M = M'$","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1123},"LeftTop":{"X":219,"Y":971},"RightBottom":{"X":2621,"Y":1123},"RightTop":{"X":2621,"Y":971}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"● If they match, the signature is valid","Level":0,"Polygon":{"LeftBottom":{"X":323,"Y":1196},"LeftTop":{"X":323,"Y":1123},"RightBottom":{"X":1314,"Y":1196},"RightTop":{"X":1314,"Y":1123}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"• Indeed, no one but Alice, who has private key $S_A$, could have produced such an object $C$, so that $M' = E_{P_A}(C)$","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1371},"LeftTop":{"X":219,"Y":1207},"RightBottom":{"X":2662,"Y":1371},"RightTop":{"X":2662,"Y":1207}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"● Only disadvantage, the signature is as long as the message!","Level":0,"Polygon":{"LeftBottom":{"X":219,"Y":1457},"LeftTop":{"X":219,"Y":1381},"RightBottom":{"X":2137,"Y":1457},"RightTop":{"X":2137,"Y":1381}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"● Compare it with real life signatures!","Level":0,"Polygon":{"LeftBottom":{"X":323,"Y":1528},"LeftTop":{"X":323,"Y":1462},"RightBottom":{"X":1337,"Y":1528},"RightTop":{"X":1337,"Y":1462}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}