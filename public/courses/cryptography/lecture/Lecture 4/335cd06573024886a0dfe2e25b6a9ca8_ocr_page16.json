{"PageNumber":16,"Angle":0,"RotatedAngle":0,"Height":1620,"Width":2880,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Simple attacks on crypto systems: MITM","Level":0,"Polygon":{"LeftBottom":{"X":216,"Y":310},"LeftTop":{"X":216,"Y":188},"RightBottom":{"X":2365,"Y":310},"RightTop":{"X":2365,"Y":188}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"• Bob (M, S): (C,S) -> Eve (C',S') -> Alice (C',S'): (M',S')??","Level":0,"Polygon":{"LeftBottom":{"X":225,"Y":514},"LeftTop":{"X":225,"Y":433},"RightBottom":{"X":1959,"Y":514},"RightTop":{"X":1959,"Y":433}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"● Note that $M'$ will be different from the original message $M$","Level":0,"Polygon":{"LeftBottom":{"X":231,"Y":616},"LeftTop":{"X":231,"Y":537},"RightBottom":{"X":2109,"Y":616},"RightTop":{"X":2109,"Y":537}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● When Alice verifies the digital signature $S'$, she obtains message $M'$ by encrypting $S'$","Level":0,"Polygon":{"LeftBottom":{"X":335,"Y":699},"LeftTop":{"X":335,"Y":626},"RightBottom":{"X":2633,"Y":699},"RightTop":{"X":2633,"Y":626}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● Thus, Alice is led to believe that Bob has signed M' instead of M","Level":0,"Polygon":{"LeftBottom":{"X":335,"Y":778},"LeftTop":{"X":335,"Y":707},"RightBottom":{"X":2091,"Y":778},"RightTop":{"X":2091,"Y":707}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● Note that in the above attacks the adversary can arbitrarily alter the transmitted ciphertext or signature","Level":0,"Polygon":{"LeftBottom":{"X":228,"Y":953},"LeftTop":{"X":228,"Y":804},"Ri