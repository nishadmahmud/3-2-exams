{"PageNumber":14,"Angle":0,"RotatedAngle":0,"Height":817,"Width":1089,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Software Quality Assurance vs Software Testing","Level":0,"Polygon":{"LeftBottom":{"X":27,"Y":63},"LeftTop":{"X":27,"Y":23},"RightBottom":{"X":792,"Y":63},"RightTop":{"X":792,"Y":23}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"title","Text":"##  Scope","Level":0,"Polygon":{"LeftBottom":{"X":94,"Y":228},"LeftTop":{"X":94,"Y":197},"RightBottom":{"X":174,"Y":228},"RightTop":{"X":174,"Y":197}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"• Quality Assurance: QA is concerned with the overall quality of the software product and the processes used to create it. It encompasses activities like establishing quality standards, defining testing methodologies, conducting reviews, and ensuring compliance with industry regulations.","Level":0,"Polygon":{"LeftBottom":{"X":119,"Y":448},"LeftTop":{"X":119,"Y":249},"RightBottom":{"X":972,"Y":448},"RightTop":{"X":972,"Y":249}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"● Testing: Testing focuses on identifying defects and ensuring that the software meets functional and non-functional requirements. It involves activities like test planning, test case design, test execution, and defect reporting.","Level":0,"Polygon":{"LeftBottom":{"X":119,"Y":623},"LeftTop":{"X":119,"Y":463},"RightBottom":{"X":1006,"Y":623},"RightTop":{"X":1006,"Y":463}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"footer","Text":"13","Level":0,"Polygon":{"LeftBottom":{"X":1043,"Y":786},"LeftTop":{"X":1043,"Y":764},"RightBottom":{"X":1064,"Y":786},"RightTop":{"X":1064,"Y":764}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}