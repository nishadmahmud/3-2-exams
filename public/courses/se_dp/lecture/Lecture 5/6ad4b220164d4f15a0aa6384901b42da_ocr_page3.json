{"PageNumber":3,"Angle":0,"RotatedAngle":0,"Height":817,"Width":1089,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Verification vs Validation i","Level":0,"Polygon":{"LeftBottom":{"X":26,"Y":63},"LeftTop":{"X":26,"Y":22},"RightBottom":{"X":457,"Y":63},"RightTop":{"X":457,"Y":22}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"table","Text":"<table><tr><td>Verification</td></tr><tr><td>Verification: Process of determining if the software is designed and developed as per the specified requirements.</td></tr><tr><td>Static analysis method (review) is done without executing code.</td></tr><tr><td>Validation</td></tr><tr><td>Validation: Process of checking if the software (end product) has met the client&#x27;s true needs and expectations.</td></tr><tr><td>Dynamic analysis method (functional, non-functional testing) is done by executing code.</td></tr></table>","Level":0,"Polygon":{"LeftBottom":{"X":83,"Y":634},"LeftTop":{"X":83,"Y":154},"RightBottom":{"X":1006,"Y":634},"RightTop":{"X":1006,"Y":154}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"footer","Text":"2","Level":0,"Polygon":{"LeftBottom":{"X":1051,"Y":786},"LeftTop":{"X":1051,"Y":767},"RightBottom":{"X":1066,"Y":786},"RightTop":{"X":1066,"Y":767}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}