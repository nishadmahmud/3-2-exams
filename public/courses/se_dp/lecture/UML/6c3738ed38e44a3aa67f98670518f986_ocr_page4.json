{"PageNumber":4,"Angle":0,"RotatedAngle":0,"Height":2376,"Width":1836,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"title","Text":"#  Sequence/Interaction/Collaboration Diagram","Level":0,"Polygon":{"LeftBottom":{"X":210,"Y":267},"LeftTop":{"X":210,"Y":219},"RightBottom":{"X":1159,"Y":267},"RightTop":{"X":1159,"Y":219}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"A sequence diagram is an interaction diagram. From the name, it is clear that the diagram deals with some sequences, which are the sequence of messages flowing from one object to another.","Level":0,"Polygon":{"LeftBottom":{"X":210,"Y":419},"LeftTop":{"X":210,"Y":286},"RightBottom":{"X":1620,"Y":419},"RightTop":{"X":1620,"Y":286}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"Interaction among the components of a system is very important from implementation and execution perspective. Sequence diagram is used to visualize the sequence of calls in a system to perform a specific functionality.","Level":0,"Polygon":{"LeftBottom":{"X":210,"Y":604},"LeftTop":{"X":210,"Y":471},"RightBottom":{"X":1620,"Y":604},"RightTop":{"X":1620,"Y":471}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"The purpose of interaction diagram is –","Level":0,"Polygon":{"LeftBottom":{"X":210,"Y":692},"LeftTop":{"X":210,"Y":656},"RightBottom":{"X":786,"Y":692},"RightTop":{"X":786,"Y":656}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"● To capture the dynamic behaviour of a system.","Level":0,"Polygon":{"LeftBottom":{"X":267,"Y":739},"LeftTop":{"X":267,"Y":697},"RightBottom":{"X":1106,"Y":739},"RightTop":{"X":1106,"Y":697}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"● To describe the message flow in the system.","Level":0,"Polygon":{"LeftBottom":{"X":267,"Y":785},"LeftTop":{"X":267,"Y":744},"RightBottom":{"X":1062,"Y":785},"RightTop":{"X":1062,"Y":744}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"● To describe the structural organization of the objects.","Level":0,"Polygon":{"LeftBottom":{"X":267,"Y":832},"LeftTop":{"X":267,"Y":792},"RightBottom":{"X":1212,"Y":832},"RightTop":{"X":1212,"Y":792}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"● To describe the interaction among objects.","Level":0,"Polygon":{"LeftBottom":{"X":267,"Y":877},"LeftTop":{"X":267,"Y":837},"RightBottom":{"X":1030,"Y":877},"RightTop":{"X":1030,"Y":837}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"Resource: https://www.geeksforgeeks.org/unified-modeling-language-uml-sequence-diagrams/","Level":0,"Polygon":{"LeftBottom":{"X":210,"Y":1105},"LeftTop":{"X":210,"Y":1020},"RightBottom":{"X":1535,"Y":1105},"RightTop":{"X":1535,"Y":1020}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}