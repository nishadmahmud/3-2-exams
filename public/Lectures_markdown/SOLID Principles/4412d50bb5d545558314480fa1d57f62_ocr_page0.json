{"PageNumber":0,"Angle":0,"RotatedAngle":0,"Height":2160,"Width":1620,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":508},"LeftTop":{"X":99,"Y":158},"RightBottom":{"X":1565,"Y":508},"RightTop":{"X":1565,"Y":158}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"graph TD     A[Single Responsibility Principle (SRP)] --> B[O]     L --> C[D]     E[Open-Closed Principle (OCP)] --> D          D --> E[Interface Segregation Principle (ISP)]","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":508},"LeftTop":{"X":99,"Y":158},"RightBottom":{"X":1565,"Y":508},"RightTop":{"X":1565,"Y":158}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/d6f871b8638d32a46f8e9a06462b03b5-image.png","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"The S.O.L.I.D principles are a set of five design principles that help software developers create more maintainable, flexible, and scalable software systems. They were introduced by Robert C. Martin (also known as Uncle Bob) in the early 2000s.","Level":0,"Polygon":{"LeftBottom":{"X":122,"Y":741},"LeftTop":{"X":122,"Y":547},"RightBottom":{"X":1510,"Y":741},"RightTop":{"X":1510,"Y":547}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"Following SOLID principles might make your codebase bigger at first. But in the long run, they help developers change their code without messing things up.","Level":0,"Polygon":{"LeftBottom":{"X":122,"Y":849},"LeftTop":{"X":122,"Y":748},"RightBottom":{"X":1473,"Y":849},"RightTop":{"X":1473,"Y":748}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":1592},"LeftTop":{"X":99,"Y":871},"RightBottom":{"X":1308,"Y":1592},"RightTop":{"X":1308,"Y":871}},"InsetImageName":"","Elemen